# Copy this file to tools/ghidra/.env and adjust paths for your machine.

# Path to Ghidra's PyGhidra headless launcher.
# macOS Homebrew example:
# GHIDRA_HEADLESS=/opt/homebrew/opt/ghidra/libexec/support/pyghidraRun
GHIDRA_HEADLESS=

# Path to a JDK supported by your Ghidra install.
# macOS Homebrew example:
# JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home
JAVA_HOME=

# Path to the Ghidra project that contains the CPS3 program.
GHIDRA_PROJECT=

# Program/file name inside the Ghidra project.
GHIDRA_PROGRAM=sfiii3nr1-combined
